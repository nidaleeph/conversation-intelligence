# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ddre_warroom

# Server
CORS_ORIGIN=http://localhost:3000

# Auth
SESSION_SECRET=change-me-to-a-random-string
MAGIC_LINK_BASE_URL=http://localhost:3000

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@ddre.com

# AI Classification (Phase 2)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# WhatsApp Web (unofficial — whatsapp-web.js)
# Set ENABLED=true to receive messages from WhatsApp groups via wwebjs
# Scan QR on first start, then session persists in SESSION_PATH
# GROUP_ALLOWLIST is a comma-separated list of group names; empty = all groups
WHATSAPP_WEB_ENABLED=false
WHATSAPP_WEB_SESSION_PATH=./whatsapp-session
WHATSAPP_WEB_GROUP_ALLOWLIST=

# WhatsApp Business API
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_APP_SECRET=your-app-secret
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# Web Push (Phase 4)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@ddre.com
